    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "diff": "^7.0.0",
    "hono": "^4.12.10",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
