# ajisai-mcp configuration
# Copy this to .env and fill in your values

# Transport: "stdio" (default) or "http"
# AJISAI_TRANSPORT=http
# AJISAI_PORT=3000

# Data directory (default: ~/.ajisai)
# AJISAI_DATA_DIR=~/.ajisai

# Authentication (HTTP mode)
# AJISAI_AUTH_PASSWORD=your-secure-password
# AJISAI_AUTH_TOKEN=your-static-bearer-token
# AJISAI_BASE_URL=https://your-domain.com

# S3 archive (optional — omit for local-only mode)
# AJISAI_S3_BUCKET=your-bucket
# AJISAI_S3_REGION=ap-northeast-1
# AJISAI_S3_PREFIX=ajisai
# AJISAI_S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
