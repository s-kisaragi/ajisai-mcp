{
  "name": "ajisai-mcp",
  "version": "0.1.0",
  "description": "MCP server for persistent Claude memory with versioning",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ajisai-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
